---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { getEntryPath } from "@/utils/contentEntry";
import Datetime from "./Datetime.astro";
import IconGallery from "@/assets/icons/IconGallery.svg";

type Props = {
  variant?: "h2" | "h3";
  featured?: boolean;
} & (CollectionEntry<"blog"> | CollectionEntry<"galleries">);

const { variant: Heading = "h2", featured = false, id, data, filePath, collection } = Astro.props;

const { title, description, pubDatetime } = data;
const modDatetime = "modDatetime" in data ? data.modDatetime : null;
const timezone = "timezone" in data ? data.timezone : undefined;
const href = getEntryPath({ collection, id, filePath });
const isGallery = collection === "galleries";
const headingId = `${collection}-${slugifyStr(String(id))}-title`;
const descriptionId = `${collection}-${slugifyStr(String(id))}-description`;

---

<li
  class:list={[
    "card-glow group/card relative my-3 rounded-2xl p-4 sm:p-5",
    "border backdrop-blur-sm",
    "transition-[border-color,background-color,box-shadow,transform] duration-300 ease-out motion-reduce:transform-none motion-reduce:transition-none",
    "hover:-translate-y-0.5 focus-within:-translate-y-0.5",
    "hover:shadow-lg focus-within:shadow-lg",

    // Default posts styling
    !isGallery && !featured && [
      "border-border/25 bg-muted/10",
      "hover:border-accent/40 hover:bg-accent/5 focus-within:border-accent/40 focus-within:bg-accent/5",
      "hover:shadow-accent/10 focus-within:shadow-accent/10",
    ],

    // Featured generic posts styling
    !isGallery && featured && [
      "border-amber-500/30 bg-amber-500/5",
      "hover:border-amber-500/50 hover:bg-amber-500/10 focus-within:border-amber-500/50 focus-within:bg-amber-500/10",
      "hover:shadow-amber-500/10 focus-within:shadow-amber-500/10",
      "shadow-[0_0_20px_-5px_rgba(245,158,11,0.15)]",
    ],

    // Gallery variant styling
    isGallery && !featured && [
      "border-purple-500/20 bg-purple-500/5",
      "hover:border-purple-500/40 hover:bg-purple-500/10 focus-within:border-purple-500/40 focus-within:bg-purple-500/10",
      "hover:shadow-purple-500/10 focus-within:shadow-purple-500/10",
    ],

    // Featured gallery styling
    isGallery && featured && [
      "border-purple-500/40 bg-purple-500/10",
      "hover:border-purple-500/60 hover:bg-purple-500/15 focus-within:border-purple-500/60 focus-within:bg-purple-500/15",
      "hover:shadow-purple-500/20 focus-within:shadow-purple-500/20",
      "shadow-[0_0_20px_-5px_rgba(168,85,247,0.15)]",
    ],
  ]}
>
  <!-- Cursor-following glow -->
  <div
    class="card-glow-effect pointer-events-none absolute inset-0 z-0 rounded-2xl opacity-0 transition-opacity duration-300 motion-reduce:transition-none group-hover/card:opacity-100 group-focus-within/card:opacity-100"
    aria-hidden="true"
  >
  </div>

  <div class="relative z-5">
    <a
      href={href}
      class:list={[
        "text-lg font-semibold text-foreground transition-colors duration-200 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-offset-2 focus-visible:ring-offset-background rounded-sm",
        isGallery 
          ? "group-hover/card:text-purple-400 focus-visible:ring-purple-500" 
          : featured 
            ? "group-hover/card:text-amber-500 focus-visible:ring-amber-500"
            : "group-hover/card:text-accent focus-visible:ring-accent"
      ]}
      aria-labelledby={headingId}
      aria-describedby={descriptionId}

    >
      <Heading id={headingId} class="flex items-center gap-2">
        {isGallery && (
          <span
            aria-hidden="true"
            class="inline-flex items-center justify-center rounded-md bg-purple-500/10 p-1 text-purple-400/80 ring-1 ring-purple-500/20"
          >
            <IconGallery class="size-4" />
          </span>
        )}
        {isGallery && <span class="sr-only">Gallery:</span>}
        {title}
      </Heading>
      <!-- Expand clickable area to whole card on top of everything, minus the description -->
      <span class="absolute -inset-4 sm:-inset-5 z-10" aria-hidden="true"></span>
    </a>
    
    <Datetime pubDatetime={pubDatetime} modDatetime={modDatetime} timezone={timezone} class="relative z-20 mt-1.5 pointer-events-none" />
    
    <p
      id={descriptionId}
      class="relative z-20 mt-2 line-clamp-2 text-sm leading-relaxed text-foreground/75 pointer-events-auto select-text"
    >
      {description}
    </p>
  </div>
</li>

<style>
  .card-glow {
    contain: paint;
  }

  .card-glow-effect {
    background: radial-gradient(
      350px circle at var(--mouse-x, 50%) var(--mouse-y, 50%),
      color-mix(in oklab, var(--accent) 8%, transparent) 0%,
      color-mix(in oklab, var(--accent) 4%, transparent) 30%,
      color-mix(in oklab, var(--accent) 0.8%, transparent) 60%,
      transparent 80%
    );
    will-change: opacity;
  }

  @media (prefers-reduced-motion: reduce) {
    .card-glow-effect {
      background: none;
    }
  }
</style>
